# Copy to .env.local and fill in after provisioning (see CONVEX_SETUP.md).
# Until BOTH are set, the app runs in standalone mock mode (no backend).

# From `npx convex dev` (printed in the terminal / Convex dashboard):
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# From the Clerk dashboard → API Keys → Publishable key:
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
